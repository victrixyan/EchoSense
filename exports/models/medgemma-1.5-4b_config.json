{
  "conversion_info": {
    "phase": 3,
    "model_name": "medgemma-1.5-4b",
    "quantization": "4-bit",
    "max_memory_gb": 2.0,
    "device": "cpu"
  },
  "inputs": {
    "prompt_text": {
      "type": "String",
